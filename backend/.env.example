# =========================
# LLM provider
# 可选：mock / deepseek / openai
# - mock: 不调用外部模型，适合本地联调
# - deepseek: 使用 DeepSeek API
# - openai: 使用 OpenAI API
# =========================
LLM_PROVIDER=deepseek

# =========================
# LLM model
# DeepSeek 常用：
# - deepseek-chat
# OpenAI 常用：
# - gpt-4o-mini
# =========================
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=8192
LLM_CHUNK_TARGET_CHARS=6000

# =========================
# DeepSeek
# 使用 DeepSeek 时填写
# 官方兼容 OpenAI 风格接口
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =========================
# OpenAI
# 使用 OpenAI 时填写
# =========================
OPENAI_API_KEY=

# =========================
# Whisper / faster-whisper
# 模型可选：tiny / base / small / medium / large-v3
# 速度优先推荐：
# - GPU: WHISPER_DEVICE=cuda, WHISPER_COMPUTE_TYPE=float16
# - CPU: WHISPER_DEVICE=cpu,  WHISPER_COMPUTE_TYPE=int8
# =========================
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# =========================
# Upload
# =========================
MAX_UPLOAD_SIZE_MB=500

# =========================
# 可选：自定义数据目录
# 不填则默认使用 backend/data
# INTERVIEW_AGENT_DATA_DIR=
# =========================
